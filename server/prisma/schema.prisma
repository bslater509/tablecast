// =============================================================================
// Tablecast — Prisma Schema
// Defines all core data models as specified in dnd-local-server-design-doc.md §4
// Provider: SQLite  |  Generated client output: default (node_modules/.prisma)
//
// Note: SQLite does not support native enum types.
// Role and GridType values are stored as String with application-level validation.
// Valid Role values:     "DM" | "PLAYER"
// Valid GridType values: "SQUARE" | "HEX"
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // DATABASE_URL must resolve to a writable path.
  // In Docker this is mounted at /app/server/prisma/data/tablecast.db
  url      = env("DATABASE_URL")
}

// =============================================================================
// Models
// =============================================================================

/// A person who connects to the Tablecast server.
/// role: "DM" | "PLAYER"  (enforced at the application layer)
/// The DM has elevated permissions: wiki editing, backup triggers, fog of war.
model User {
  id       Int    @id @default(autoincrement())
  username String @unique

  /// "DM" or "PLAYER"
  role String @default("PLAYER")

  // Custom 3D Dice styling preferences
  diceTheme String @default("default")
  diceColor String @default("#7c3aed")

  // Relations
  characters Character[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

/// A D&D 5e character sheet linked to a player User.
/// Core ability scores are stored as individual integer columns for easy querying.
/// Inventory and computed modifiers are stored as JSON strings (SQLite TEXT).
model Character {
  id Int @id @default(autoincrement())

  // Owner
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  name  String
  race  String @default("")
  class String @default("")
  level Int    @default(1)

  // Hit Points
  hp    Int @default(10)
  maxHp Int @default(10)

  // Core Ability Scores (D&D 5e)
  strength     Int @default(10)
  dexterity    Int @default(10)
  constitution Int @default(10)
  intelligence Int @default(10)
  wisdom       Int @default(10)
  charisma     Int @default(10)

  // JSON blobs — calculated by the frontend; stored for persistence
  // inventory: serialized array of item objects
  // modifiers: serialized map of ability modifier values
  inventory String @default("[]") // JSON array
  modifiers String @default("{}") // JSON object

  // Relations
  tokens                Token[]
  encounterParticipants EncounterParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("characters")
}

/// A virtual tabletop map loaded as a background image.
/// fogState stores the DM's fog-of-war polygon data as a JSON string.
/// gridType: "SQUARE" | "HEX"  (enforced at the application layer)
model Map {
  id       Int    @id @default(autoincrement())
  name     String
  imageUrl String // Path within uploads/ or external URL
  gridSize Int    @default(50) // pixels per grid cell

  /// "SQUARE" or "HEX"
  gridType String @default("SQUARE")

  // Fog of War — JSON array of polygon coordinate arrays drawn by the DM
  fogState String @default("[]") // JSON

  // Relations
  tokens     Token[]
  encounters Encounter[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("maps")
}

/// A draggable marker on a Map, optionally linked to a Character.
/// x/y coordinates represent grid cell position (not pixel position).
model Token {
  id Int @id @default(autoincrement())

  // Which map this token lives on
  mapId Int
  map   Map @relation(fields: [mapId], references: [id], onDelete: Cascade)

  // Optional link to a character sheet (monster tokens may have no character)
  characterId Int?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  // Optional link to an NPC sheet
  npcId Int?
  npc   Npc? @relation(fields: [npcId], references: [id], onDelete: SetNull)

  // Display
  label    String @default("")
  imageUrl String @default("")

  // Grid position (column, row) — updated in real-time via Socket.io
  x Float @default(0)
  y Float @default(0)

  // JSON blob containing bestiary stats if it is a monster token
  stats String?

  // Optional combat tracker participant linked to this token
  encounterParticipants EncounterParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tokens")
}

/// A DM wiki article — NPCs, locations, lore, session notes, etc.
/// When isVisibleToPlayers is true the article appears in the Player Journal tab.
model WikiArticle {
  id                 Int     @id @default(autoincrement())
  title              String
  content            String  @default("") // Rich text / Markdown
  isVisibleToPlayers Boolean @default(false)
  category           String  @default("LORE")

  // JSON array of tag strings, e.g. ["NPC","Neverwinter"]
  tags String @default("[]") // JSON

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("wiki_articles")
}

/// Small key/value store for DM-controlled server settings.
model AppSetting {
  key       String   @id
  value     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

/// A DM-created Non-Player Character (NPC) template with a 5e monster-like statblock
model Npc {
  id    Int    @id @default(autoincrement())
  name  String
  race  String @default("")
  class String @default("")
  level Int    @default(1)

  // Combat Stats
  hp       Int    @default(10)
  maxHp    Int    @default(10)
  ac       Int    @default(10)
  cr       String @default("0") // e.g. "1/8", "1", "10"
  imageUrl String @default("")
  largeImageUrl String @default("")

  // Core Ability Scores (D&D 5e)
  strength     Int @default(10)
  dexterity    Int @default(10)
  constitution Int @default(10)
  intelligence Int @default(10)
  wisdom       Int @default(10)
  charisma     Int @default(10)

  // JSON blobs for structured stats
  // inventory: serialized array of item objects
  // modifiers: serialized map of ability modifier values (strength, dexterity, etc.)
  // actions: serialized array of action objects { name, description, toHit, damage }
  inventory String @default("[]") // JSON array
  modifiers String @default("{}") // JSON object
  actions   String @default("[]") // JSON array

  // Narrative and player visibility
  description        String  @default("")
  alignment          String  @default("")
  appearance         String  @default("")
  personality        String  @default("")
  history            String  @default("")
  partyRelationship  String  @default("")
  isVisibleToPlayers Boolean @default(false)

  // Relations
  tokens                Token[]
  encounterParticipants EncounterParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("npcs")
}

/// A prepared or active combat encounter for a specific map.
/// status: "DRAFT" | "ACTIVE" | "COMPLETE"  (enforced at the application layer)
model Encounter {
  id    Int    @id @default(autoincrement())
  name  String
  mapId Int
  map   Map    @relation(fields: [mapId], references: [id], onDelete: Cascade)

  status    String @default("DRAFT")
  round     Int    @default(1)
  turnIndex Int    @default(0)

  participants EncounterParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("encounters")
}

/// A combatant in an encounter. It may be linked to a token, NPC, or character.
model EncounterParticipant {
  id          Int       @id @default(autoincrement())
  encounterId Int
  encounter   Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  tokenId Int?
  token   Token? @relation(fields: [tokenId], references: [id], onDelete: SetNull)

  npcId Int?
  npc   Npc? @relation(fields: [npcId], references: [id], onDelete: SetNull)

  characterId Int?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  name       String
  initiative Int     @default(0)
  currentHp  Int     @default(1)
  maxHp      Int     @default(1)
  ac         Int     @default(10)
  isHidden   Boolean @default(false)
  sortOrder  Int     @default(0)
  source     String  @default("")
  imageUrl   String  @default("")
  stats      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("encounter_participants")
}
