// =============================================================================
// Tablecast — Prisma Schema
// Defines all core data models as specified in dnd-local-server-design-doc.md §4
// Provider: SQLite  |  Generated client output: default (node_modules/.prisma)
//
// Note: SQLite does not support native enum types.
// Role and GridType values are stored as String with application-level validation.
// Valid Role values:     "DM" | "PLAYER"
// Valid GridType values: "SQUARE" | "HEX"
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // DATABASE_URL must resolve to a writable path.
  // In Docker this is mounted at /app/server/prisma/data/tablecast.db
  url      = env("DATABASE_URL")
}

// =============================================================================
// Models
// =============================================================================

/// A person who connects to the Tablecast server.
/// role: "DM" | "PLAYER"  (enforced at the application layer)
/// The DM has elevated permissions: wiki editing, backup triggers, fog of war.
model User {
  id       Int    @id @default(autoincrement())
  username String @unique

  /// "DM" or "PLAYER"
  role String @default("PLAYER")

  /// scrypt hash of the DM's password. null = not set (setup mode).
  passwordHash String?

  // Dice preferences for 3D dice theming
  diceTheme String @default("default")
  diceColor String @default("#7c3aed")

  // Relations
  characters      Character[]
  chatMessages    ChatMessage[]
  aiConversations AiConversation[]
  handoutsCreated Handout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

/// A persisted session chat message. This stores regular chat, dice roll chat
/// cards, NPC replies, and system/AI messages that should survive reloads.
model ChatMessage {
  id String @id @default(cuid())

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  characterId Int?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  sender String
  text   String
  type   String @default("user")

  // JSON object for dice roll payloads. Null for plain chat.
  rollDetails String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([characterId])
  @@index([type])
  @@map("chat_messages")
}

/// A D&D 5e character sheet — the primary identity for players.
/// Can optionally be owned by a DM user for management purposes.
/// Core ability scores are stored as individual integer columns for easy querying.
/// Inventory and computed modifiers are stored as JSON strings (SQLite TEXT).
model Character {
  id Int @id @default(autoincrement())

  // Optional owner (DM user only — PLAYER users no longer exist)
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Identity
  name  String
  race  String @default("")
  class String @default("")
  level Int    @default(1)

  // Hit Points
  hp    Int @default(10)
  maxHp Int @default(10)

  // Core Ability Scores (D&D 5e)
  strength     Int @default(10)
  dexterity    Int @default(10)
  constitution Int @default(10)
  intelligence Int @default(10)
  wisdom       Int @default(10)
  charisma     Int @default(10)

  // Custom 3D Dice styling preferences (per-hero)
  diceTheme String @default("default")
  diceColor String @default("#7c3aed")

  // Hit Dice — used for short/long rest recovery
  // hitDiceType: class hit die type (d6, d8, d10, d12)
  // hitDiceTotal: total hit dice available (normally equal to level)
  // hitDiceUsed: how many hit dice have been spent since last long rest
  hitDiceType  String @default("d10")
  hitDiceTotal Int    @default(1)
  hitDiceUsed  Int    @default(0)

  // Currency tracking: JSON string { pp, gp, ep, sp, cp }
  currency String @default("{\"pp\":0,\"gp\":0,\"ep\":0,\"sp\":0,\"cp\":0}")

  // Gold in copper pieces (100 cp = 1 gp) — simplified single-number tracking
  gold Int @default(0)

  // JSON blobs — calculated by the frontend; stored for persistence
  // inventory: serialized array of item objects
  // modifiers: serialized map of ability modifier values
  inventory String @default("[]") // JSON array
  modifiers String @default("{}") // JSON object

  // Spellcasting fields
  // spellSlots: JSON object tracking per-level slot usage e.g. {"1":{"total":4,"used":0},"2":{"total":3,"used":0}}
  // spells: JSON array of spell objects {name, level, school, prepared, description, ...}
  spellSlots         String @default("{}")  // JSON
  spells             String @default("[]")  // JSON
  spellcastingAbility String @default("")
  spellSaveDc        Int    @default(10)
  spellAttackBonus   Int    @default(5)

  // Relations
  tokens                Token[]
  encounterParticipants EncounterParticipant[]
  chatMessages          ChatMessage[]
  rolls                 Roll[]
  aiConversations       AiConversation[]
  partyMembers          PartyMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("characters")
}

/// A virtual tabletop map loaded as a background image.
/// fogState stores the DM's fog-of-war polygon data as a JSON string.
/// gridType: "SQUARE" | "HEX"  (enforced at the application layer)
model Map {
  id       Int    @id @default(autoincrement())
  name     String
  imageUrl String // Path within uploads/ or external URL
  gridSize Int    @default(50) // pixels per grid cell

  /// "SQUARE" or "HEX"
  gridType String @default("SQUARE")

  // Fog of War — JSON array of polygon coordinate arrays drawn by the DM
  fogState String @default("[]") // JSON

  // Dynamic Lighting — JSON array of wall segments [{x1,y1,x2,y2}]
  walls String @default("[]") // JSON

  // Relations
  tokens             Token[]
  encounters         Encounter[]
  encounterTemplates EncounterTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("maps")
}

/// A draggable marker on a Map, optionally linked to a Character.
/// x/y coordinates represent grid cell position (not pixel position).
model Token {
  id Int @id @default(autoincrement())

  // Which map this token lives on
  mapId Int
  map   Map @relation(fields: [mapId], references: [id], onDelete: Cascade)

  // Optional link to a character sheet (monster tokens may have no character)
  characterId Int?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  // Optional link to an NPC sheet
  npcId Int?
  npc   Npc? @relation(fields: [npcId], references: [id], onDelete: SetNull)

  // Optional link to a Monster sheet
  monsterId Int?
  monster   Monster? @relation(fields: [monsterId], references: [id], onDelete: SetNull)

  // Display
  label    String @default("")
  imageUrl String @default("")

  // Grid position (column, row) — updated in real-time via Socket.io
  x Float @default(0)
  y Float @default(0)

  // JSON blob containing bestiary stats if it is a monster token
  stats String?

  // Conditions — JSON array of condition objects [{name, color}]
  conditions String @default("[]") // JSON

  // Vision & Lighting
  visionRadius     Float @default(0) // light source radius in grid cells (0=unlimited for DM)
  darkvisionRadius Float @default(0) // darkvision range in grid cells

  // Aura
  auraRadius Float @default(0) // aura radius in grid cells
  auraColor  String @default("") // aura hex color, e.g. "#ff6600"

  // Optional combat tracker participant linked to this token
  encounterParticipants EncounterParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mapId])
  @@index([characterId])
  @@index([npcId])
  @@index([monsterId])
  @@map("tokens")
}

/// A DM wiki article — NPCs, locations, lore, session notes, etc.
/// When isVisibleToPlayers is true the article appears in the Player Journal tab.
model WikiArticle {
  id                 Int     @id @default(autoincrement())
  title              String
  content            String  @default("") // Rich text / Markdown
  isVisibleToPlayers Boolean @default(false)
  category           String  @default("LORE")

  // JSON array of tag strings, e.g. ["NPC","Neverwinter"]
  tags String @default("[]") // JSON

  /// GameSessions that link this article as their wikiLog
  gameSessions GameSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isVisibleToPlayers])
  @@map("wiki_articles")
}

/// A DM-created shop where player characters can buy and sell items.
model Shop {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @default("")
  /// Price multiplier (1.0 = normal, 0.5 = half price, 2.0 = premium)
  markup      Float    @default(1.0)
  /// Whether the shop is currently open for business
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items ShopItem[]

  @@map("shops")
}

/// An item available for purchase in a Shop.
model ShopItem {
  id          Int      @id @default(autoincrement())
  shopId      Int
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  name        String
  description String   @default("")
  /// Price in copper pieces
  price       Int      @default(0)
  /// Stock quantity (-1 = unlimited)
  quantity    Int      @default(1)
  /// "weapon", "armor", "potion", "scroll", "wondrous", "ammunition", "gear", "magic-item", etc.
  category    String   @default("")
  isMagical   Boolean  @default(false)
  attunement  Boolean  @default(false)
  /// JSON array of tag strings
  tags        String   @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@map("shop_items")
}

/// Small key/value store for DM-controlled server settings.
model AppSetting {
  key       String   @id
  value     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

/// A DM-created Non-Player Character (NPC) template with a 5e monster-like statblock
model Npc {
  id    Int    @id @default(autoincrement())
  name  String
  race  String @default("")
  class String @default("")
  level Int    @default(1)

  // Combat Stats
  hp       Int    @default(10)
  maxHp    Int    @default(10)
  ac       Int    @default(10)
  cr       String @default("0") // e.g. "1/8", "1", "10"
  imageUrl String @default("")
  largeImageUrl String @default("")

  // Core Ability Scores (D&D 5e)
  strength     Int @default(10)
  dexterity    Int @default(10)
  constitution Int @default(10)
  intelligence Int @default(10)
  wisdom       Int @default(10)
  charisma     Int @default(10)

  // JSON blobs for structured stats
  // inventory: serialized array of item objects
  // modifiers: serialized map of ability modifier values (strength, dexterity, etc.)
  // actions: serialized array of action objects { name, description, toHit, damage }
  inventory String @default("[]") // JSON array
  modifiers String @default("{}") // JSON object
  actions   String @default("[]") // JSON array

  // Narrative and player visibility
  description        String  @default("")
  alignment          String  @default("")
  appearance         String  @default("")
  personality        String  @default("")
  history            String  @default("")
  partyRelationship  String  @default("")
  isVisibleToPlayers Boolean @default(false)

  // Dialogue tree — JSON object { nodes: [...], startNodeId: "..." }
  // Each node has: { id, type (SPEECH|CHOICE|CONDITION|ACTION|RANDOM|SKILL_CHECK), ...type-specific fields }
  dialogueTree String @default("{}") // JSON

  // TTS voice settings (for §5.3 TTS feature)
  voice     String @default("")
  voicePitch Float  @default(1.0)
  voiceRate  Float  @default(1.0)

  // Relations
  tokens                Token[]
  encounterParticipants EncounterParticipant[]
  aiConversations       AiConversation[]
  questsGiven           Quest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@map("npcs")
}

/// A quest or mission tracked by the DM and visible to players in their Journal.
/// status: "ACTIVE" | "COMPLETED" | "FAILED"
model Quest {
  id Int @id @default(autoincrement())

  title       String
  description String @default("")

  /// "ACTIVE", "COMPLETED", or "FAILED"
  status String @default("ACTIVE")

  /// JSON array of objective objects: [{ description, type (KILL|FETCH|ESCORT|EXPLORE|TALK|CRAFT), isComplete, progress, target }]
  objectives String @default("[]") // JSON

  /// JSON object: { xp, gold, items: [{name, quantity}] }
  rewards String @default("{}") // JSON

  /// Optional link to quest-giver NPC
  questGiverNpcId Int?
  questGiverNpc   Npc?  @relation(fields: [questGiverNpcId], references: [id], onDelete: SetNull)

  /// Optional link to parent quest (for quest chains)
  parentQuestId Int?
  parentQuest   Quest? @relation("QuestChain", fields: [parentQuestId], references: [id], onDelete: SetNull)

  /// Child quests in the chain
  childQuests Quest[] @relation("QuestChain")

  /// JSON array of character IDs this quest is assigned to (empty = party-wide)
  assignedToCharacterIds String @default("[]") // JSON

  /// Whether players can see this quest
  isVisibleToPlayers Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([questGiverNpcId])
  @@index([parentQuestId])
  @@map("quests")
}

/// A DM-created handout (image, document, secret note) targeted at specific characters.
model Handout {
  id Int @id @default(autoincrement())

  title   String
  content String @default("")

  /// Optional image attachment URL
  imageUrl String @default("")

  /// JSON array of character IDs this handout is visible to (empty = all players)
  targetCharacterIds String @default("[]") // JSON

  /// Whether all targeted players have read it
  isRead Boolean @default(false)

  /// Creator (DM user)
  createdByDmId Int
  createdByDm   User   @relation(fields: [createdByDmId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdByDmId])
  @@map("handouts")
}

/// A prepared or active combat encounter for a specific map.
/// status: "DRAFT" | "ACTIVE" | "COMPLETE"  (enforced at the application layer)
model Encounter {
  id    Int    @id @default(autoincrement())
  name  String
  mapId Int
  map   Map    @relation(fields: [mapId], references: [id], onDelete: Cascade)

  status    String @default("DRAFT")
  round     Int    @default(1)
  turnIndex Int    @default(0)

  participants EncounterParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mapId])
  @@index([status])
  @@map("encounters")
}

/// A combatant in an encounter. It may be linked to a token, NPC, or character.
model EncounterParticipant {
  id          Int       @id @default(autoincrement())
  encounterId Int
  encounter   Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  tokenId Int?
  token   Token? @relation(fields: [tokenId], references: [id], onDelete: SetNull)

  npcId Int?
  npc   Npc? @relation(fields: [npcId], references: [id], onDelete: SetNull)

  characterId Int?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  monsterId Int?
  monster   Monster? @relation(fields: [monsterId], references: [id], onDelete: SetNull)

  name       String
  initiative Int     @default(0)
  currentHp  Int     @default(1)
  maxHp      Int     @default(1)
  ac         Int     @default(10)
  isHidden   Boolean @default(false)
  sortOrder  Int     @default(0)
  source     String  @default("")
  imageUrl   String  @default("")
  stats      String?

  // Conditions — JSON array of {name, color, duration, remainingRounds}
  conditions String @default("[]") // JSON

  // Death Saves — JSON object {successes, failures, isStable}
  deathSaves String @default("{\"successes\":0,\"failures\":0,\"isStable\":false}") // JSON

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([encounterId])
  @@index([tokenId])
  @@index([npcId])
  @@index([characterId])
  @@index([monsterId])
  @@map("encounter_participants")
}

// TODO (#22): Audit/log tables (mcp_logs, ai_response_logs) grow unbounded.
// Consider implementing a retention policy: delete records older than N days,
// either via a scheduled job or a capped table approach.

/// A history record of a dice roll made by a hero or DM.
model Roll {
  id        Int      @id @default(autoincrement())
  sender    String

  characterId Int?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  rollName  String   @default("Dice Roll")
  formula   String
  rolls     String   // Store as JSON string: e.g. "[18]" or "[10, 5]"
  modifier  Int      @default(0)
  total     Int
  diceTheme String   @default("default")
  diceColor String   @default("#7c3aed")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([characterId])
  @@map("rolls")
}

/// A planned, active, or completed D&D play session with prep notes and recap.
/// status: "PLANNED" | "ACTIVE" | "COMPLETED"  (enforced at the application layer)
model GameSession {
  id Int @id @default(autoincrement())

  title         String
  sessionNumber Int?

  /// "PLANNED", "ACTIVE", or "COMPLETED"
  status String @default("PLANNED")

  scheduledFor DateTime?

  agenda        String @default("")
  prepChecklist String @default("[]") // JSON array of { id, text, done }
  recap         String @default("")

  /// Optional link to a published WikiArticle with category "LOG"
  wikiLogId Int?
  wikiLog   WikiArticle? @relation(fields: [wikiLogId], references: [id], onDelete: SetNull)

  linkedWikiIds      String @default("[]") // JSON array of wiki article IDs
  linkedMapIds       String @default("[]") // JSON array of map IDs
  linkedEncounterIds String @default("[]") // JSON array of encounter IDs

  isVisibleToPlayers Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([scheduledFor])
  @@map("game_sessions")
}

/// A persisted AI conversation (Rules Scholar or NPC Roleplay session).
/// Conversations group a sequence of user+assistant messages for continuity.
model AiConversation {
  id        Int         @id @default(autoincrement())
  userId    Int?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  characterId Int?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  /// "rules" or "npc"
  type      String      @default("rules")

  /// If type="npc", which NPC persona is being roleplayed
  npcId     Int?
  npc       Npc?        @relation(fields: [npcId], references: [id], onDelete: SetNull)

  /// Optional auto/summary title
  title     String      @default("")

  messages  AiMessage[]

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
  @@index([characterId])
  @@index([npcId])
  @@map("ai_conversations")
}

/// A single message in an AI conversation.
model AiMessage {
  id             Int             @id @default(autoincrement())
  conversationId Int
  conversation   AiConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  /// "user" or "assistant"
  role           String
  text           String

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([createdAt])
  @@map("ai_messages")
}

/// Audit log of Model Context Protocol (MCP) tool invocations by AI agents.
/// Captures tool name, arguments, result, and error status for debugging.
model McpLog {
  id        Int      @id @default(autoincrement())
  tool      String
  arguments String   // JSON string of tool arguments
  result    String?  // JSON string of tool result or error text
  isError   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tool])
  @@index([createdAt])
  @@map("mcp_logs")
}

/// Persisted raw responses from AI provider API calls.
/// Stores full prompt and reply for debugging LLM output issues.
model AiResponseLog {
  id         Int      @id @default(autoincrement())
  operation  String   // e.g. "npc-generate", "chat-stream", "encounter-build"
  prompt     String   // The prompt sent to the AI
  rawReply   String   // Full raw text response from the AI provider
  parsedOk   Boolean  // Whether JSON parsing of the response succeeded
  errorMsg   String?  // Error message if parsing failed or call errored
  durationMs Int?     // Duration of the AI call in milliseconds
  createdAt  DateTime @default(now())

  @@index([operation])
  @@index([createdAt])
  @@index([parsedOk])
  @@map("ai_response_logs")
}

/// A DM-imported Non-Player Character (Monster) template with a 5e bestiary statblock
model Monster {
  id    Int    @id @default(autoincrement())
  name  String
  race  String @default("")
  class String @default("")
  level Int    @default(1)

  // Combat Stats
  hp            Int    @default(10)
  maxHp         Int    @default(10)
  ac            Int    @default(10)
  cr            String @default("0")
  imageUrl      String @default("")
  largeImageUrl String @default("")

  // Core Ability Scores (D&D 5e)
  strength     Int @default(10)
  dexterity    Int @default(10)
  constitution Int @default(10)
  intelligence Int @default(10)
  wisdom       Int @default(10)
  charisma     Int @default(10)

  // JSON blobs for structured stats
  // inventory: serialized array of item objects
  // modifiers: serialized map of ability modifier values
  // actions: serialized array of action objects
  inventory String @default("[]")
  modifiers String @default("{}")
  actions   String @default("[]")

  // Narrative and player visibility
  description        String  @default("")
  alignment          String  @default("")
  appearance         String  @default("")
  personality        String  @default("")
  history            String  @default("")
  partyRelationship  String  @default("")
  isVisibleToPlayers Boolean @default(false)

  // Relations
  tokens                Token[]
  encounterParticipants EncounterParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@map("monsters")
}

/// A shared party vault for group inventory and gold management
model Party {
  id Int @id @default(autoincrement())
  name String @default("Party")
  /// Shared inventory: JSON array of item objects [{ name, quantity, weight, description }]
  inventory String @default("[]")
  /// Shared gold pool: JSON string for per-currency tracking { pp, gp, ep, sp, cp }
  currency String @default("{\"pp\":0,\"gp\":0,\"ep\":0,\"sp\":0,\"cp\":0}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members PartyMember[]

  @@map("parties")
}

/// An audio track in the DM's Soundboard for ambient music and sound effects.
/// Files are stored on disk at server/uploads/audio/ and metadata in DB.
model Soundtrack {
  id        Int      @id @default(autoincrement())
  name      String
  /// Category: COMBAT, EXPLORATION, TOWN, TAVERN, DUNGEON, WILDERNESS, AMBIENT
  category  String   @default("AMBIENT")
  /// Relative path under server/uploads/audio/
  filePath  String
  /// Duration in seconds (0 = unknown)
  duration  Int      @default(0)
  /// Whether the track loops by default
  loop      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("soundtracks")
}

/// A DM-created homebrew content entry (custom races, classes, feats, spells, magic items, monsters).
/// type: "RACE" | "CLASS" | "FEAT" | "SPELL" | "MAGIC_ITEM" | "MONSTER"
/// content: JSON whose schema varies by type (see features.md §4.3 for full schemas).
model HomebrewEntry {
  id        Int      @id @default(autoincrement())
  /// RACE | CLASS | FEAT | SPELL | MAGIC_ITEM | MONSTER
  type      String
  name      String
  /// DM's custom source label (e.g. "My Campaign", "Homebrew")
  source    String   @default("")
  /// Semver string (e.g. "1.0.0")
  version   String   @default("1.0.0")
  /// JSON blob — schema varies by type. Contains the full definition.
  content   String   @default("{}")
  /// JSON array of tag strings
  tags      String   @default("[]")
  /// Whether this entry is active/available for use
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([name])
  @@index([isActive])
  @@map("homebrew_entries")
}

/// Generated loot results that have been "kept unclaimed" by the DM for later assignment.
/// Stores the full loot result data as JSON for later assignment to party inventory.
model LootCache {
  id        Int      @id @default(autoincrement())
  /// Label describing where the loot came from (e.g. "Goblin Ambush", "CR 5 Hoard")
  label     String   @default("")
  /// JSON: full loot result { coins: {...}, gems: [...], art: [...], magicItems: [...] }
  data      String   @default("{}")
  /// Total value in GP (cached for sorting/display)
  totalValue Float   @default(0)
  /// CR tier that generated this loot
  tier String @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("loot_caches")
}

/// Links a Character to a Party
model PartyMember {
  id Int @id @default(autoincrement())
  partyId Int
  characterId Int
  role String @default("MEMBER") // MEMBER | LEADER | QUARTERMASTER

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([partyId, characterId])
  @@map("party_members")
}

/// A reusable encounter template that DMs can load and apply to create encounters.
/// difficulty: "easy" | "medium" | "hard" | "deadly"
/// participants: JSON array of { sourceType, sourceId?, name, count }
model EncounterTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  description String @default("")

  /// "easy", "medium", "hard", or "deadly"
  difficulty String @default("medium")
  recommendedLevel Int @default(1)

  /// JSON array of tag strings
  tags String @default("[]") // JSON

  /// JSON array of participant templates:
  /// [{ sourceType: "npc"|"monster"|"character"|"placeholder", sourceId?, name, count }]
  participants String @default("[]") // JSON

  /// Optional link to a recommended map
  mapId Int?
  map   Map? @relation(fields: [mapId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([difficulty])
  @@index([recommendedLevel])
  @@map("encounter_templates")
}
